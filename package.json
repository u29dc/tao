{
	"name": "tao",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git@github.com:u29dc/tao.git"
	},
	"scripts": {
		"core --------------------------------------------": "",
		"prepare": "husky",
		"dev": "./target/release/tao",
		"build": "bun run release:all",
		"update": "cargo update && bun update --latest",
		"release -----------------------------------------": "",
		"release:all": "./scripts/release.sh --target all",
		"release:cli": "./scripts/release.sh --target cli",
		"release:mac": "./scripts/release.sh --target mac",
		"util --------------------------------------------": "",
		"util:clean": "./scripts/clean.sh",
		"util:ffi": "./scripts/ffi.sh",
		"util:safety": "./scripts/safety.sh --check-repo",
		"util:format": "cargo fmt --all",
		"util:lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
		"util:types": "cargo check --workspace --release",
		"util:test": "cargo test --workspace --release",
		"util:swift": "bun run util:ffi && swift test --configuration release --package-path apps/tao-macos",
		"util:audit": "cargo audit",
		"util:check": "bun run util:safety && bun run util:format && bun run util:lint && bun run util:types && bun run util:test && bun run util:swift && bun run util:audit && bun run build",
		"bench -------------------------------------------": "",
		"bench": "./scripts/bench.sh --suite all",
		"bench:all": "./scripts/bench.sh --suite all",
		"bench:smoke": "./scripts/bench.sh --suite cli --profile 1k --runs 1 --warmup 0",
		"bench:sdk": "./scripts/bench.sh --suite sdk",
		"bench:cli": "./scripts/bench.sh --suite cli",
		"bench:daemon": "./scripts/bench.sh --suite daemon",
		"bench:fixtures": "./scripts/bench.sh --suite fixtures",
		"bench:budget": "./scripts/budgets.sh --profile 10k",
		"bench:bridge": "./scripts/bench.sh --suite bridge",
		"bench:ffi": "./scripts/bench.sh --suite ffi",
		"bench:startup": "./scripts/bench.sh --suite startup"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3"
	}
}
