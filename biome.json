{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"files": {
		"ignoreUnknown": true
	},
	"formatter": {
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "es5"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab"
		}
	}
}
